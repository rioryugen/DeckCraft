# DeckCraft Environment Configuration
# Copy this file to .env and fill in your values

# LLM Provider: openai | google | anthropic | ollama | custom
LLM=custom

# Custom LLM endpoint (OpenAI-compatible)
CUSTOM_LLM_URL=https://models.github.ai/inference
CUSTOM_MODEL=openai/gpt-4.1
CUSTOM_LLM_API_KEY=

# Standard providers (uncomment as needed)
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# ANTHROPIC_API_KEY=

# Application settings
DISABLE_THINKING=false
DISABLE_IMAGE_GENERATION=true
DISABLE_AUTH=true
APP_DATA_DIRECTORY=./app_data
MEM0_ENABLED=false
MIGRATE_DATABASE_ON_STARTUP=true
DISABLE_ANONYMOUS_TRACKING=true
